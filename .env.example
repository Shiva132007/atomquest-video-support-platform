# =============================================
#  AtomQuest — Environment Variable Reference
#  Copy to .env and fill in your values
# =============================================

# Server Port (Railway sets this automatically — do NOT set in Railway dashboard)
PORT=3000

# REQUIRED: Change this to a long random string!
# Generate one: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=CHANGE_ME_TO_A_LONG_RANDOM_SECRET

# mediasoup Network Config
# On Railway/Render/cloud: leave MEDIASOUP_LISTEN_IP as 0.0.0.0
# MEDIASOUP_ANNOUNCED_IP is auto-detected from the server's public IP at startup
MEDIASOUP_LISTEN_IP=0.0.0.0
MEDIASOUP_ANNOUNCED_IP=

# WebRTC UDP port range — open these in your cloud firewall!
RTC_MIN_PORT=20000
RTC_MAX_PORT=20100

# Environment
NODE_ENV=production

# Database file path
DB_PATH=./data.db

# OPTIONAL: Override the public URL shown in invite links
# Leave empty to auto-detect from the request origin
# Example: PUBLIC_URL=https://myapp.up.railway.app
PUBLIC_URL=

# OPTIONAL: Metered.ca TURN credentials (register free at https://www.metered.ca/tools/openrelay/)
# Adding these enables video calls across ALL networks (mobile data etc.)
TURN_SERVER_URL=
TURN_USERNAME=
TURN_CREDENTIAL=
