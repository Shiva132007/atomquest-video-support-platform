{
  "name": "atomquest-video-support",
  "version": "1.0.0",
  "description": "Real-Time Video Support Platform — AtomQuest Hackathon 1.0",
  "scripts": {
    "start": "node --experimental-sqlite server/index.js",
    "dev": "nodemon --experimental-sqlite server/index.js",
    "dev:full": "concurrently \"npm run dev\" \"npm run client\"",
    "client": "npm run dev --prefix frontend",
    "build:frontend": "npm run build --prefix frontend",
    "launch": "node --experimental-sqlite launch.js"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.1",
    "express": "^4.18.2",
    "jsonwebtoken": "^9.0.2",
    "mediasoup": "^3.14.0",
    "mediasoup-client": "^3.20.0",
    "multer": "^1.4.5-lts.1",
    "socket.io": "^4.7.2",
    "uuid": "^9.0.0"
  },
  "devDependencies": {
    "nodemon": "^3.0.3",
    "concurrently": "^8.2.2"
  },
  "engines": {
    "node": ">=22.5.0"
  }
}
